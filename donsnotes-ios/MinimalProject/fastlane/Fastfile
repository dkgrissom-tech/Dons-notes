default_platform(:ios)

platform :ios do
  desc "Deploy to TestFlight"
  lane :beta do
    # NOTE: In-App Purchase product IDs in App Store Connect:
    #   com.donsnotes.app.pro.monthly        — Auto-Renewable Subscription, $12.99/mo  ✅
    #   com.donsnotes.app.orapro.monthly     — Auto-Renewable Subscription, $19.99/mo  ✅
    #   com.donsnotes.app.lifetime           — Non-Consumable, $149  (set price in ASC)
    # Subscription group name: "Ora Pro"
    # Reference name for each: Pro Monthly, Ora Pro Monthly, Lifetime Access
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: "#{ENV["HOME"]}/.appstoreconnect/private_keys/AuthKey_#{ENV["APP_STORE_CONNECT_API_KEY_ID"]}.p8",
      in_house: false
    )

    # Auto-increment build number based on latest TestFlight build to avoid
    # 'bundle version already used' upload failures.
    latest_build = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: ENV["APP_BUNDLE_ID"] || "com.donsnotes.app",
      initial_build_number: 0
    )
    increment_build_number(
      build_number: latest_build + 1,
      xcodeproj: "DonsNotes.xcodeproj"
    )

    build_app(
      scheme: "DonsNotes",
      project: "DonsNotes.xcodeproj",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "DonsNotes.ipa",
      xcargs: "CODE_SIGN_STYLE=Manual PROVISIONING_PROFILE_SPECIFIER='match AppStore com.donsnotes.app' DEVELOPMENT_TEAM=#{ENV["APPLE_TEAM_ID"]} CODE_SIGN_IDENTITY='Apple Distribution' ELEVENLABS_API_KEY='#{ENV["ELEVENLABS_API_KEY"]}' ELEVENLABS_VOICE_ID='#{ENV["ELEVENLABS_VOICE_ID"]}' GROQ_API_KEY='#{ENV["GROQ_API_KEY"]}'",
      export_options: {
        method: "app-store",
        provisioningProfiles: {
          "com.donsnotes.app" => "match AppStore com.donsnotes.app"
        },
        signingStyle: "manual",
        teamID: ENV["APPLE_TEAM_ID"]
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )

    # ── Post-upload checklist (automated) ────────────────────────────────────
    # Apple takes ~5 minutes to process the build before the API exposes it.
    # We poll until it appears, then:
    #   1. Set usesNonExemptEncryption = false  (clears MISSING_EXPORT_COMPLIANCE)
    #   2. Add to internal TestFlight group     (aca5f162-a25f-4d25-ba57-165c98b1aa55)
    #   3. Add to external TestFlight group     (03dff58c-e0bd-4276-b720-5fcd9dfde010)
    UI.message("Waiting for Apple to process the build (polling every 30s, up to 10 min)...")

    app_id           = "6777510925"
    internal_group   = "aca5f162-a25f-4d25-ba57-165c98b1aa55"
    external_group   = "03dff58c-e0bd-4276-b720-5fcd9dfde010"
    expected_version = get_version_number(xcodeproj: "DonsNotes.xcodeproj", target: "DonsNotes")
    expected_build   = get_build_number(xcodeproj: "DonsNotes.xcodeproj")

    build_id = nil
    20.times do |i|
      sleep(30) if i > 0
      UI.message("Poll #{i + 1}/20 — looking for version #{expected_version} build #{expected_build}...")
      builds_json = sh(
        "curl -sf -H 'Authorization: Bearer #{ENV["ASC_JWT"]}' " \
        "'https://api.appstoreconnect.apple.com/v1/builds?filter[app]=#{app_id}&sort=-uploadedDate&limit=10' 2>&1",
        log: false
      ) rescue nil
      next unless builds_json

      require "json"
      data = JSON.parse(builds_json) rescue nil
      next unless data && data["data"]

      match = data["data"].find do |b|
        b.dig("attributes", "version") == expected_build.to_s &&
          (b.dig("attributes", "processingState") == "VALID" ||
           b.dig("attributes", "processingState") == "VALID_BUT_MISSING_USAGES")
      end

      if match
        build_id = match["id"]
        UI.success("Build found: #{build_id}")
        break
      end
    end

    unless build_id
      UI.error("Build did not appear in ASC within 10 minutes — run post-upload steps manually.")
      next
    end

    jwt = ENV["ASC_JWT"]

    # 1. Export compliance
    UI.message("Setting usesNonExemptEncryption = false...")
    sh(
      "curl -sf -X PATCH " \
      "-H 'Authorization: Bearer #{jwt}' " \
      "-H 'Content-Type: application/json' " \
      "-d '{\"data\":{\"type\":\"builds\",\"id\":\"#{build_id}\"," \
          "\"attributes\":{\"usesNonExemptEncryption\":false}}}' " \
      "'https://api.appstoreconnect.apple.com/v1/builds/#{build_id}' > /dev/null 2>&1 || true",
      log: false
    )
    UI.success("Export compliance set.")

    # 2. Internal TestFlight group
    UI.message("Adding to internal TestFlight group...")
    sh(
      "curl -sf -X POST " \
      "-H 'Authorization: Bearer #{jwt}' " \
      "-H 'Content-Type: application/json' " \
      "-d '{\"data\":[{\"type\":\"builds\",\"id\":\"#{build_id}\"}]}' " \
      "'https://api.appstoreconnect.apple.com/v1/betaGroups/#{internal_group}/relationships/builds' " \
      "> /dev/null 2>&1 || true",
      log: false
    )
    UI.success("Added to internal group.")

    # 3. External TestFlight group
    UI.message("Adding to external TestFlight group...")
    sh(
      "curl -sf -X POST " \
      "-H 'Authorization: Bearer #{jwt}' " \
      "-H 'Content-Type: application/json' " \
      "-d '{\"data\":[{\"type\":\"builds\",\"id\":\"#{build_id}\"}]}' " \
      "'https://api.appstoreconnect.apple.com/v1/betaGroups/#{external_group}/relationships/builds' " \
      "> /dev/null 2>&1 || true",
      log: false
    )
    UI.success("Added to external group. Post-upload checklist complete ✅")
  end

  desc "Submit to App Store for review"
  lane :release do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: "#{ENV["HOME"]}/.appstoreconnect/private_keys/AuthKey_#{ENV["APP_STORE_CONNECT_API_KEY_ID"]}.p8",
      in_house: false
    )

    # Upload metadata (description, keywords, release notes)
    deliver(
      api_key: api_key,
      app_identifier: ENV["APP_BUNDLE_ID"] || "com.donsnotes.app",
      metadata_path: "./fastlane/metadata",
      skip_screenshots: true,     # add screenshots manually in App Store Connect first
      skip_binary_upload: true,   # reuse latest TestFlight build
      submit_for_review: true,
      automatic_release: false,   # manual release so you control launch timing
      force: true,
      submission_information: {
        add_id_info_uses_idfa: false,
        content_rights_has_rights: true,
        content_rights_contains_third_party_content: false,
        export_compliance_encryption_updated: false,
        export_compliance_uses_encryption: false
      }
    )
  end
end
