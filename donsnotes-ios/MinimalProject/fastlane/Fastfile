default_platform(:ios)

platform :ios do
  desc "Deploy to TestFlight"
  lane :beta do
    # NOTE: In-App Purchase product IDs in App Store Connect:
    #   com.donsnotes.app.pro.monthly        — Auto-Renewable Subscription, $12.99/mo  ✅
    #   com.donsnotes.app.orapro.monthly     — Auto-Renewable Subscription, $19.99/mo  ✅
    #   com.donsnotes.app.lifetime           — Non-Consumable, $149  (set price in ASC)
    # Subscription group name: "Ora Pro"
    # Reference name for each: Pro Monthly, Ora Pro Monthly, Lifetime Access
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: "#{ENV["HOME"]}/.appstoreconnect/private_keys/AuthKey_#{ENV["APP_STORE_CONNECT_API_KEY_ID"]}.p8",
      in_house: false
    )

    # Auto-increment build number based on latest TestFlight build to avoid
    # 'bundle version already used' upload failures.
    latest_build = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: ENV["APP_BUNDLE_ID"] || "com.donsnotes.app",
      initial_build_number: 0
    )
    increment_build_number(
      build_number: latest_build + 1,
      xcodeproj: "DonsNotes.xcodeproj"
    )

    build_app(
      scheme: "DonsNotes",
      project: "DonsNotes.xcodeproj",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "DonsNotes.ipa",
      xcargs: "CODE_SIGN_STYLE=Manual PROVISIONING_PROFILE_SPECIFIER='match AppStore com.donsnotes.app' DEVELOPMENT_TEAM=#{ENV["APPLE_TEAM_ID"]} CODE_SIGN_IDENTITY='Apple Distribution' ELEVENLABS_API_KEY='#{ENV["ELEVENLABS_API_KEY"]}' ELEVENLABS_VOICE_ID='#{ENV["ELEVENLABS_VOICE_ID"]}' GROQ_API_KEY='#{ENV["GROQ_API_KEY"]}'",
      export_options: {
        method: "app-store",
        provisioningProfiles: {
          "com.donsnotes.app" => "match AppStore com.donsnotes.app"
        },
        signingStyle: "manual",
        teamID: ENV["APPLE_TEAM_ID"]
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Submit to App Store for review"
  lane :release do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: "#{ENV["HOME"]}/.appstoreconnect/private_keys/AuthKey_#{ENV["APP_STORE_CONNECT_API_KEY_ID"]}.p8",
      in_house: false
    )

    # Upload metadata (description, keywords, release notes)
    deliver(
      api_key: api_key,
      app_identifier: ENV["APP_BUNDLE_ID"] || "com.donsnotes.app",
      metadata_path: "./fastlane/metadata",
      skip_screenshots: true,     # add screenshots manually in App Store Connect first
      skip_binary_upload: true,   # reuse latest TestFlight build
      submit_for_review: true,
      automatic_release: false,   # manual release so you control launch timing
      force: true,
      submission_information: {
        add_id_info_uses_idfa: false,
        content_rights_has_rights: true,
        content_rights_contains_third_party_content: false,
        export_compliance_encryption_updated: false,
        export_compliance_uses_encryption: false
      }
    )
  end
end
